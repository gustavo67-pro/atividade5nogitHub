programa {
  funcao inicio() {
    real n1, n2
    escreva("Digite 2 números e veja qual é maior: \n")
    leia(n1)
    leia(n2)
    se (n1>n2)
    escreva("O numero ",n1 ," é maior que ", n2)
    se(n1 == n2)
    escreva("eles sao iguais")
    senao 
    escreva("O numero ", n2, " é maior que ", n1)
  }
}
